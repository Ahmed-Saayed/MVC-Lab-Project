@using Lab2.Models.ViewModels
@model CourseVM
@{
    ViewData["Title"] = "Add_Course";
    SelectList options = new SelectList(Model.departments, "Department_ID", "Dep_Name");
}

<h1>Add Course</h1>

<form asp-action="SaveAdded" asp-controller="Course" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">
            <span asp-for="Course_Name"></span>
            <span class="text-danger ms-2" asp-validation-for="Course_Name"></span>
        </label>
        <input asp-for="Course_Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            <span asp-for="Degree"></span>
            <span class="text-danger ms-2" asp-validation-for="Degree"></span>
        </label>
        <input asp-for="Degree" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            <span asp-for="Min_Degree"></span>
            <span class="text-danger ms-2" asp-validation-for="Min_Degree"></span>
        </label>
        <input asp-for="Min_Degree" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            <span asp-for="hourse"></span>
            <span class="text-danger ms-2" asp-validation-for="hourse"></span>
        </label>
        <input asp-for="hourse" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            <span asp-for="Dep_ID">Department</span>
            <span class="text-danger ms-2" asp-validation-for="Dep_ID"></span>
        </label>
        <select asp-for="Dep_ID" asp-items="@options" class="form-select">
            <option value="">-- Select Department --</option>
        </select>
    </div>

    <input type="submit" value="Save" class="btn btn-success mt-2" />
</form>