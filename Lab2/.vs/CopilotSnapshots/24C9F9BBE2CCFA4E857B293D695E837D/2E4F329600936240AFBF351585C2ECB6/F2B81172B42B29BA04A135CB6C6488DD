@using Lab2.Models.ViewModels
@model CourseVM
@{
    ViewData["Title"] = "Add_Course";
    SelectList options = new SelectList(Model.departments, "Department_ID", "Dep_Name");
}

<h1>Add Course</h1>

<form asp-action="SaveAdded" asp-controller="Course" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label asp-for="Course_Name"></label>
        <input asp-for="Course_Name" class="form-control" />
        <span asp-validation-for="Course_Name" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Degree"></label>
        <input asp-for="Degree" class="form-control" />
        <span asp-validation-for="Degree" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Min_Degree"></label>
        <input asp-for="Min_Degree" class="form-control" />
        <span asp-validation-for="Min_Degree" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="hourse"></label>
        <input asp-for="hourse" class="form-control" />
        <span asp-validation-for="hourse" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Dep_ID">Department</label>
        <select asp-for="Dep_ID" asp-items="@options" class="form-select">
            <option value="">-- Select Department --</option>
        </select>
        <span asp-validation-for="Dep_ID" class="text-danger"></span>
    </div>

    <input type="submit" value="Save" class="btn btn-success mt-2" />
</form>