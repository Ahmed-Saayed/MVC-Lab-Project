using System.ComponentModel.DataAnnotations;
using Lab2.Models.Validation;

namespace Lab2.Models.ViewModels
{
    public class CourseVM
    {
        [Required]
        [StringLength(20, MinimumLength = 2)]
        [UniqueCourse(ErrorMessage = "Course name must be unique within the department")]
        public string Course_Name { get; set; }

        [Required]
        [Range(50, 100, ErrorMessage = "Degree must be between 50 and 100")]
        public int Degree { get; set; }

        [Required]
        [LessThan("Degree", ErrorMessage = "Min degree must be less than Degree")]
        public int Min_Degree { get; set; }

        [Required]
        [DivisibleBy(3, ErrorMessage = "Hours must be divisible by 3")]
        public string hourse { get; set; }

        public int Dep_ID { get; set; }
        public List<Department> departments { get; set; }
    }
}
