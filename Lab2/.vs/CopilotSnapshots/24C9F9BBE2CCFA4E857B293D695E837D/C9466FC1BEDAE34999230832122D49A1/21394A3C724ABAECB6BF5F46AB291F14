@using Lab2.Models.ViewModels
@model CourseVM
@{
    ViewData["Title"] = "Add_Course";
    SelectList options = new SelectList(Model.departments, "Department_ID", "Dep_Name");
}

<h1>Add Course</h1>

<form asp-action="SaveAdded" asp-controller="Course" method="post" novalidate>
    <div class="mb-3">
        <label class="form-label" asp-for="Course_Name"></label>
        <span class="text-danger small d-block" asp-validation-for="Course_Name"></span>
        <input asp-for="Course_Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="Degree"></label>
        <span class="text-danger small d-block" asp-validation-for="Degree"></span>
        <input asp-for="Degree" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="Min_Degree"></label>
        <span class="text-danger small d-block" asp-validation-for="Min_Degree"></span>
        <input asp-for="Min_Degree" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="hourse"></label>
        <span class="text-danger small d-block" asp-validation-for="hourse"></span>
        <input asp-for="hourse" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="Dep_ID">Department</label>
        <span class="text-danger small d-block" asp-validation-for="Dep_ID"></span>
        <select asp-for="Dep_ID" asp-items="@options" class="form-select">
            <option value="">-- Select Department --</option>
        </select>
    </div>

    <input type="submit" value="Save" class="btn btn-success mt-2" />
</form>
