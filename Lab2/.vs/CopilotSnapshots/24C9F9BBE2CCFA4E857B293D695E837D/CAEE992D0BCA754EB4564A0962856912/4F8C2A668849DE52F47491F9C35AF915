using System.Collections.Generic;
using Lab2.Models.ViewModels;
using Lab2.Models;

namespace Lab2.Services
{
    public static class CourseValidationService
    {
        public static List<KeyValuePair<string, string>> Validate(CourseVM vm, DataCon con)
        {
            var errors = new List<KeyValuePair<string, string>>();
            if (vm == null) 
                return errors;

            // Min degree must be less than Degree
            if (vm.Min_Degree >= vm.Degree)
                errors.Add(new KeyValuePair<string, string>(nameof(vm.Min_Degree), "Min degree must be less than Degree"));

            // Hours must be divisible by 3
            if (vm.hourse % 3 != 0)
                errors.Add(new KeyValuePair<string, string>(nameof(vm.hourse), "Hours must be divisible by 3"));

            return errors;
        }
    }
}
