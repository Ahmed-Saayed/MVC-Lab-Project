using Humanizer;
using Lab2.Models.ViewModels;
using Lab2.Models;
using Microsoft.AspNetCore.Mvc;


namespace Lab2.Controllers
{
    public class CourseController : Controller
    {
        DataCon con = new DataCon();
        public IActionResult Add_Course()
        {
            CourseVM coursevm = new();

            coursevm.departments = con.Departments.ToList();
            return View("Add_Course", coursevm);
        }

        [HttpPost]
        public IActionResult SaveAdded(CourseVM coursevm)
        {
            if (!ModelState.IsValid)
            {
                coursevm.departments = con.Departments.ToList();
                return View("Add_Course", coursevm);
            }

            if (con.Courses.Any(c => c.Course_Name == coursevm.Course_Name && c.Dep_ID == coursevm.Dep_ID))
                ModelState.AddModelError(nameof(coursevm.Course_Name), "Course name must be unique within the department");
            

            if (coursevm.Min_Degree >= coursevm.Degree)
                ModelState.AddModelError(nameof(coursevm.Min_Degree), "Min degree must be less than Degree");
            

            if (coursevm.hourse % 3 != 0)
                ModelState.AddModelError(nameof(coursevm.hourse), "Hours must be divisible by 3");
            

            if (!ModelState.IsValid)
            {
                coursevm.departments = con.Departments.ToList();
                return View("Add_Course", coursevm);
            }

            var course = new Course
            {
                Course_Name = coursevm.Course_Name,
                Degree = coursevm.Degree,
                Min_Degree = coursevm.Min_Degree,
                hourse = coursevm.hourse,
                Dep_ID = coursevm.Dep_ID
            };

            con.Courses.Add(course);
            con.SaveChanges();
            return RedirectToAction("ShowAll", "Instructor");
        }
    }
}
