@using Lab2.Models.ViewModels

@model InstructorVM
@{
    ViewData["Title"] = "Add_Instructor";
}

<h1>Add_Instructor</h1>

<form action="/Instructor/SaveAdded/" method="post">

    <div>

        <label>Name</label>
        <input type="text" name="Inst_Name" value="@Model.Inst_Name" />
    </div>

    <div>
        <label>Image</label>
        <input type="text" name="Image" value="@Model.Image" />
    </div>

    <div>
        <label>Address</label>
        <input type="text" name="Adress" value="@Model.Adress" />
    </div>

    <div>
        <label>Salary</label>
        <input type="text" name="salary" value="@Model.salary" />
    </div>

    <div>
        <label>Course</label>
        <select name="Course_id">
            @foreach (Course course in Model.courses)
            {
                <option value="@course.Course_ID">@course.Course_Name</option>
            }
        </select>
    </div>

    <div>
        <label>Department</label>
        <select name="Dep_ID">
            @foreach (Department department in Model.departments)
            {
                <option value="@department.Department_ID">@department.Dep_Name</option>
            }
        </select>
    </div>

    <input type="submit" value="Save" class="btn btn-success" />
</form>
